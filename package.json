{
  "name": "@forjio/website-ui",
  "version": "0.3.0",
  "description": "Shared marketing-site chrome (navbar, footer, docs scaffold, hero badge, fonts) for the Forjio family of SaaS products. Linksnap is the anchor.",
  "license": "UNLICENSED",
  "private": false,
  "author": "Forjio <support@forjio.com>",
  "homepage": "https://github.com/hachimi-cat/forjio-website-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hachimi-cat/forjio-website-ui.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fonts": {
      "types": "./dist/fonts/index.d.ts",
      "import": "./dist/fonts/index.js",
      "require": "./dist/fonts/index.cjs"
    },
    "./styles/marketing.css": "./dist/styles/marketing.css",
    "./fonts/Gellix-Regular.woff2": "./dist/fonts/Gellix-Regular.woff2",
    "./fonts/Gellix-Medium.woff2": "./dist/fonts/Gellix-Medium.woff2",
    "./fonts/Gellix-SemiBold.woff2": "./dist/fonts/Gellix-SemiBold.woff2",
    "./fonts/Gellix-Bold.woff2": "./dist/fonts/Gellix-Bold.woff2"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0"
  },
  "peerDependencies": {
    "lucide-react": ">=0.300.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-react": "^0.400.0",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "forjio",
    "marketing",
    "ui",
    "navbar",
    "footer",
    "docs"
  ]
}